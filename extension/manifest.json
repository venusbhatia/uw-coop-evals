{
  "manifest_version": 3,
  "name": "WaterlooWorks Co-op Evaluation Auto-Filler",
  "version": "1.0",
  "description": "Auto-fills student performance evaluation forms on WaterlooWorks using data fetched from the local Evals Hub.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.waterlooworks.uwaterloo.ca/*",
    "http://localhost:8090/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.waterlooworks.uwaterloo.ca/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}

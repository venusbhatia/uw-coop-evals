# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Session auth (min 32 chars; must match JWT_PRIVATE_KEY on Convex dashboard)
SESSION_SECRET=generate_with_openssl_rand_base64_32
SESSION_ISSUER=https://employee-evals.vercel.app

# AI providers
XAI_API_KEY=
DEEPGRAM_API_KEY=

# Chrome extension export route
EXTENSION_API_KEY=

# Optional: allow any @8090.inc user to run seedDemo in production
ALLOW_SEED_DEMO=false

# Per-IP rate limits (production: use Upstash for global limits)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_CHAT_PER_HOUR=30
# RATE_LIMIT_TRANSCRIBE_PER_HOUR=60

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Session auth (RS256) — run: node scripts/generate-jwt-keys.mjs
JWT_PRIVATE_KEY=
JWKS=
SESSION_ISSUER=https://employee-evals.vercel.app

# AI providers
XAI_API_KEY=
DEEPGRAM_API_KEY=

# Chrome extension export route
EXTENSION_API_KEY=

# Optional: allow any @8090.inc user to run seedDemo (local dev only recommended)
ALLOW_SEED_DEMO=false

# Role assignment (comma-separated emails, set in Convex dashboard too)
HR_REVIEWER_EMAILS=hr@8090.inc
VP_REVIEWER_EMAILS=vp@8090.inc

# Per-IP rate limits (production: use Upstash for global limits)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_CHAT_PER_HOUR=150
# RATE_LIMIT_AUTH_PER_HOUR=100
# RATE_LIMIT_API_GENERAL_PER_HOUR=150
# Transcribe (/api/transcribe) is not rate limited

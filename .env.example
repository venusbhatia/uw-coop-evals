# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Session auth (RS256) — run: node scripts/generate-jwt-keys.mjs
JWT_PRIVATE_KEY=
JWKS=
SESSION_ISSUER=https://evals.com

# AI providers
XAI_API_KEY=
DEEPGRAM_API_KEY=

# Chrome extension export route
EXTENSION_API_KEY=

# Demo roster + "See demo" (set on Vercel and Convex for production)
ALLOW_SEED_DEMO=true

# Role assignment (comma-separated; must be set on Convex — not only .env.local)
HR_REVIEWER_EMAILS=demo-hr@evals.com
VP_REVIEWER_EMAILS=demo-vp@evals.com

# Per-IP rate limits (production: use Upstash for global limits)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_CHAT_PER_HOUR=150
# RATE_LIMIT_AUTH_PER_HOUR=100
# RATE_LIMIT_API_GENERAL_PER_HOUR=150
